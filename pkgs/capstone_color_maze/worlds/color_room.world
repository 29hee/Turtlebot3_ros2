    <model name="p_blue_l">
      <static>true</static>
      <pose>-2.405 -1.000 0.250 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.04 1.0 0.5</size></box></geometry></collision>
        <visual name="v">
