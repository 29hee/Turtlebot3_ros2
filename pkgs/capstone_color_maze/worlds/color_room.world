    <model name="obs_cyl_a">
      <static>true</static>
      <pose>-0.8 0.6 0.300 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.18</radius><length>0.6</length></cylinder></geometry></collision>
        <visual name="v">
