    <model name="obs_cyl_b">
      <static>true</static>
      <pose>0.9 1.1 0.250 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.15</radius><length>0.5</length></cylinder></geometry></collision>
        <visual name="v">
          <geometry><cylinder><radius>0.15</radius><length>0.5</length></cylinder></geometry>
