<?xml version="1.0" ?>
<!-- 자동 생성: generate_world.py — 흰벽 5x5m 방 + RGB 단색 패널 9개 + 무채색 장애물 -->
<sdf version="1.6">
  <world name="color_room">
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>
    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.8 0.8 0.8 1</background>
      <shadows>false</shadows>
    </scene>
    <physics type="ode">
      <real_time_update_rate>1000</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
    </physics>

    <model name="wall_bottom">
      <static>true</static>
      <pose>0.0 -2.5 0.250 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>5.15 0.15 0.5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>5.15 0.15 0.5</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/White</name></script></material>
        </visual>
      </link>
    </model>

    <model name="wall_top">
      <static>true</static>
      <pose>0.0 2.5 0.250 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>5.15 0.15 0.5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>5.15 0.15 0.5</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/White</name></script></material>
        </visual>
      </link>
    </model>

    <model name="wall_left">
      <static>true</static>
      <pose>-2.5 0.0 0.250 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.15 5.15 0.5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.15 5.15 0.5</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/White</name></script></material>
        </visual>
      </link>
    </model>

    <model name="wall_right">
      <static>true</static>
      <pose>2.5 0.0 0.250 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.15 5.15 0.5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.15 5.15 0.5</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/White</name></script></material>
        </visual>
      </link>
    </model>

    <model name="p_red_b">
      <static>true</static>
      <pose>-1.500 -2.405 0.250 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.0 0.04 0.5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>1.0 0.04 0.5</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Red</name></script></material>
